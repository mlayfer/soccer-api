מטעמם, ולא ניתנה כל הנחיה לשינוי ברמת הכוננות.\n\nבהודעה שהופצה נטען כי “כוננות שיא” הוכרזה במערכת וכי כלל מערך החירום התבקש להיערך לאפשרות של פינוי מיידי. נוסח ההודעה נוסח באופן רשמי לכאורה, מה שהגביר את תחושת הבהלה בקרב הורים לילדים המאושפזים ובקרב צוותים רפואיים. אלא שבשניידר מבהירים כי ההודעה אינה אותנטית.\n\nבבית החולים מדגישים כי בכל מקרה של שינוי בהנחיות או ברמת הכוננות - עדכון רשמי יופץ בערוצים הרשמיים בלבד, וקוראים לציבור שלא לשתף הודעות לא מאומתות העלולות לגרום לבהלה מיותרת.\n\n✍️ @yonatandush","has_translation":null},"caption_is_edited":false,"headline":null,"view_count":null,"top_likers":["ofirshimon24"],"facepile_top_likers":[{"profile_pic_url":"https://instagram.ftlv6-1.fna.fbcdn.net/v/t51.2885-19/455694080_816083150727898_8917148472515214899_n.jpg?stp=dst-jpg_s150x150_tt6\u0026efg=eyJ2ZW5jb2RlX3RhZyI6InByb2ZpbGVfcGljLmRqYW5nby4xMDgwLmMyIn0\u0026_nc_ht=instagram.ftlv6-1.fna.fbcdn.net\u0026_nc_cat=110\u0026_nc_oc=Q6cZ2QGd4_NX-4CWVECxC_VOhyG7vp0sgHUaP2NcmtWcH4S97BLlG3v7nD2q_FAQ2228O80\u0026_nc_ohc=NIGgEn6bOQgQ7kNvwFudXEU\u0026_nc_gid=R--GB0T6REViNfiUuP-m5A\u0026edm=AONqaaQBAAAA\u0026ccb=7-5\u0026oh=00_Aftw00uuzhj7cDtQHOTZ4Q9LKdGb47PCdy3l1pvFHlhLQA\u0026oe=699C1EED\u0026_nc_sid=4e3341","id":"550635385"}],"hidden_likes_string_variant":-1,"fb_like_count":null,"crosspost_metadata":{"is_feedback_aggregated":null,"is_feed_feedback_aggregated":null},"social_context":[{"social_context_type":"liked_by","social_context_users_count":1291,"social_context_facepile_users":[{"profile_pic_url":"https://instagram.ftlv6-1.fna.fbcdn.net/v/t51.2885-19/455694080_816083150727898_8917148472515214899_n.jpg?stp=dst-jpg_s150x150_tt6\u0026efg=eyJ2ZW5jb2RlX3RhZyI6InByb2ZpbGVfcGljLmRqYW5nby4xMDgwLmMyIn0\u0026_nc_ht=instagram.ftlv6-1.fna.fbcdn.net\u0026_nc_cat=110\u0026_nc_oc=Q6cZ2QGd4_NX-4CWVECxC_VOhyG7vp0sgHUaP2NcmtWcH4S97BLlG3v7nD2q_FAQ2228O80\u0026_nc_ohc=NIGgEn6bOQgQ7kNvwFudXEU\u0026_nc_gid=R--GB0T6REViNfiUuP-m5A\u0026edm=AONqaaQBAAAA\u0026ccb=7-5\u0026oh=00_Aftw00uuzhj7cDtQHOTZ