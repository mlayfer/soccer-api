ר על עצמי לגמרי.\nזה השפיע על מערכת החיסון שלי שנחלשה\nונכנסה לה שפעת שלא ככ עזבה עד היום בכל מיני תסמינים,\nהפך לסמי דיכאון של שבועיים בהם הכל היה עצוב וכבד\nועבר להחלטה לשנות את חיי מקצה לקצה ולצאת מהעיר\nלוותר על בית קבוע ולצאת להרפתקה במקום חדש.\nהשיעור שמלווה אותי כל החיים ומגיע בכל מיני תצורות הוא לבחור בעצמי, לסמוך על עצמי ובכך לפתח את הביטחון שלי\nלהבין שאני תלויה אך ורק בי! \nהחיים שלי הם בשליטתי ואחרים לא מנהלים אותי, רק אני הבוס פה ולבחור מה נכון עבורי ומה לא צריך לקבל את האנרגיה שלי\nאני עוד באמצע השיעור, ממש מגיעה למבחני ההסמכה וזה קשה ומצריך ממני המון שינויים בתפיסות ודפוסים שנחקקו חזק ועמוק ב31 שנות חיי\nזה תהליך כואב, ארוך ומפחיד \nאבל אני בטוחה שאם זה הגיע זו כנראה השעה הנכונה ואין לי ספק שאוכל להתמודד עם כל מה שמגיע\nבגדול זה היה החורף\nבקטן - זו אני בבגד ים שמתנגדת לו אבל חוטפת אותו חזק למערכת ואין לי ברירה אלא לקבל ולגדול \n💜⁩⁩","has_translation":null},"caption_is_edited":true,"headline":null,"view_count":null,"top_likers":[],"facepile_top_likers":[],"hidden_likes_string_variant":-1,"fb_like_count":null,"crosspost_metadata":{"is_feedback_aggregated":null,"is_feed_feedback_aggregated":null},"social_context":[],"comment_count":79,"can_reshare":null,"enable_media_notes_production":false,"media_repost_count":null,"saved_collection_ids":null,"has_viewer_saved":null,"sharing_friction_info":{"should_have_sharing_friction":false,"bloks_app_url":null},"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"can_see_insights_as_brand":false,"owner":{"show_account_transparency_details":true,"id":"52404535"},"has_audio":null,"media_notes":{"items":[]}},"view_state_item_type":null,"id":"3825663737814946170","inventory_source":"mixed_unconnected","ad":null},"end_of_feed_demarcator":null,"stories_netego":null,"suggested_users":null,"bloks_netego":null,"abra_icebreakers_in_feed_unit":null,"ad4ad_in_webfeed":null,"__typename":"XDTFeedItem"},"cursor":""},{"node":{"media":null,"ad":null,"explore_story":{"media":{"id":"3835315170696